@using InternProject.Web.Startup
@model InternProject.Web.Models.Products.ProductListViewModel
@{
    ViewBag.Title = L("Products");
    ViewBag.CurrentPageName = PageNames.Products;
}
@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/Products/Index.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/Products/Index.min.js" asp-append-version="true"></script>
    </environment>
}
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

    .content-wrapper {
        background-color: #f8fafc !important;
        font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    .content-header {
        padding: 0 !important;
    }

    /* Top Header Bar */
    .dashboard-top-header {
        border-bottom: 1px solid #e2e8f0;
        padding: 12px 0;
        font-size: 14px;
        color: #475569;
        margin-bottom: 20px;
    }
    
    .dashboard-top-header .top-header-left {
        font-weight: 600;
        color: #0f172a;
    }

    /* Main Title & Add Button */
    .products-main-title {
        font-size: 28px;
        font-weight: 700;
        color: #0f172a;
        letter-spacing: -0.02em;
    }

    .products-subtitle {
        font-size: 14px;
        color: #64748b;
        margin-top: 4px;
    }

    .btn-add-product {
        background-color: #2563eb !important;
        color: #ffffff !important;
        border-radius: 8px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 14px;
        box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.2);
        transition: all 0.2s ease-in-out;
        border: none;
        display: inline-flex;
        align-items: center;
        text-decoration: none;
    }

    .btn-add-product:hover {
        background-color: #1d4ed8 !important;
        transform: translateY(-1px);
        box-shadow: 0 6px 12px -1px rgba(37, 99, 235, 0.3);
        color: #ffffff !important;
    }

    /* KPI Cards */
    .kpi-card {
        border-radius: 16px;
        padding: 24px;
        color: #ffffff;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.05);
        transition: all 0.2s ease-in-out;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .kpi-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px -5px rgba(0, 0, 0, 0.1);
    }

    .kpi-card-blue {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    }
    
    .kpi-card-orange {
        background: linear-gradient(135deg, #f97316, #ea580c);
    }
    
    .kpi-card-green {
        background: linear-gradient(135deg, #10b981, #059669);
    }

    .kpi-icon-wrapper {
        width: 44px;
        height: 44px;
        background-color: rgba(255, 255, 255, 0.18);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .kpi-value {
        font-size: 32px;
        font-weight: 700;
        letter-spacing: -0.03em;
        margin-top: 15px;
    }

    .kpi-label {
        font-size: 14px;
        opacity: 0.9;
        margin-top: 4px;
        font-weight: 500;
    }

    /* Search & Filter Containers */
    .filter-container {
        background-color: #ffffff;
        border-radius: 12px;
        padding: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.02);
    }

    .custom-search-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .custom-search-input-wrapper .search-icon {
        position: absolute;
        left: 16px;
        color: #94a3b8;
        font-size: 16px;
    }

    .custom-search-input-wrapper input {
        padding-left: 48px;
        height: 48px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        background-color: #ffffff;
        font-size: 14px;
        color: #0f172a;
        transition: all 0.15s ease-in-out;
        width: 100%;
    }

    .custom-search-input-wrapper input:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        outline: none;
    }

    .custom-select-filter {
        height: 48px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        font-size: 14px;
        font-weight: 500;
        color: #334155;
        padding: 0 16px;
        transition: all 0.15s ease-in-out;
        width: 100%;
        background-color: #ffffff;
    }

    .custom-select-filter:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        outline: none;
    }

    /* DataTable Styles */
    .table-card {
        border: 1px solid #e2e8f0 !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02) !important;
    }

    .custom-products-table {
        border-collapse: separate !important;
        border-spacing: 0 !important;
    }

    .custom-products-table thead th {
        background-color: #f8fafc !important;
        color: #64748b !important;
        font-size: 12px !important;
        font-weight: 600 !important;
        text-transform: uppercase !important;
        letter-spacing: 0.05em !important;
        padding: 16px 20px !important;
        border-bottom: 1px solid #e2e8f0 !important;
        border-top: none !important;
    }

    .custom-products-table tbody td {
        padding: 16px 20px !important;
        vertical-align: middle !important;
        font-size: 14px !important;
        color: #334155 !important;
        border-bottom: 1px solid #f1f5f9 !important;
        background-color: #ffffff !important;
    }

    .custom-products-table tbody tr:hover td {
        background-color: #f8fafc !important;
    }

    /* Product link */
    .product-name-link {
        color: #2563eb !important;
        font-weight: 600;
        text-decoration: none;
        transition: color 0.15s ease-in-out;
    }

    .product-name-link:hover {
        color: #1d4ed8 !important;
        text-decoration: underline;
    }

    /* Status Badges */
    .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        border-radius: 9999px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-status-active {
        background-color: #d1fae5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

    .badge-status-inactive {
        background-color: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    /* Stock Badge alerts */
    .badge-stock {
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 13px;
        font-weight: 600;
        display: inline-block;
    }
    
    .badge-stock-warning {
        background-color: #fef3c7;
        color: #d97706;
    }
    
    .badge-stock-danger {
        background-color: #fee2e2;
        color: #dc2626;
        border: 1px solid #fca5a5;
    }
    
    .badge-stock-normal {
        color: #334155;
        font-weight: 500;
        padding: 0;
        background: transparent;
    }

    /* Detail link */
    .product-action-detail {
        color: #2563eb !important;
        font-weight: 500;
        text-decoration: none;
        transition: color 0.15s ease-in-out;
    }

    .product-action-detail:hover {
        color: #1d4ed8 !important;
        text-decoration: underline;
    }

    /* Pagination Styling overrides */
    .dataTables_wrapper .dataTables_paginate {
        margin: 20px 0 !important;
        padding-top: 10px !important;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 6px;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button {
        border-radius: 8px !important;
        border: 1px solid #cbd5e1 !important;
        background: #ffffff !important;
        color: #475569 !important;
        padding: 6px 14px !important;
        font-size: 13px !important;
        font-weight: 500 !important;
        cursor: pointer !important;
        transition: all 0.15s ease-in-out !important;
        margin: 0 2px !important;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
        background: #f1f5f9 !important;
        color: #0f172a !important;
        border-color: #94a3b8 !important;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button.current,
    .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
        background: #2563eb !important;
        color: #ffffff !important;
        border-color: #2563eb !important;
        font-weight: 600 !important;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button.disabled,
    .dataTables_wrapper .dataTables_paginate .paginate_button.disabled:hover {
        background: #f8fafc !important;
        color: #94a3b8 !important;
        border-color: #e2e8f0 !important;
        cursor: not-allowed !important;
    }

    .dataTables_wrapper .dataTables_info {
        font-size: 13px !important;
        color: #64748b !important;
        margin-top: 24px !important;
    }
</style>

<div class="container-fluid py-4">
    <!-- Main Title & Add Button Row -->
    <div class="products-header-row d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="products-main-title m-0">@L("ManageProducts")</h1>
            <p class="products-subtitle m-0">@L("ManageProductsSubtitle")</p>
        </div>
        <div>
            <a href="javascript:;" data-bs-toggle="modal" data-bs-target="#ProductCreateModal" class="btn btn-add-product">
                <i class="fas fa-plus mr-2"></i>
                @L("CreateProduct")
            </a>
        </div>
    </div>

    <!-- 3 Main KPI Cards -->
    <div class="row mb-4">
        <!-- Card 1: Tổng sản phẩm -->
        <div class="col-md-4 mb-3">
            <div class="kpi-card kpi-card-blue">
                <div class="kpi-card-header d-flex justify-content-between">
                    <span class="kpi-icon-wrapper"><i class="fas fa-box"></i></span>
                </div>
                <div>
                    <div class="kpi-value" id="kpi-total-products">0</div>
                    <div class="kpi-label">@L("TotalProducts")</div>
                </div>
            </div>
        </div>
        <!-- Card 2: Hết/Sắp hết hàng -->
        <div class="col-md-4 mb-3">
            <div class="kpi-card kpi-card-orange">
                <div class="kpi-card-header d-flex justify-content-between align-items-center">
                    <span class="kpi-icon-wrapper"><i class="fas fa-exclamation-triangle"></i></span>
                </div>
                <div>
                    <div class="kpi-value" id="kpi-low-stock">0</div>
                    <div class="kpi-label">@L("LowStockWarning")</div>
                </div>
            </div>
        </div>
        <!-- Card 3: Đang hoạt động -->
        <div class="col-md-4 mb-3">
            <div class="kpi-card kpi-card-green">
                <div class="kpi-card-header d-flex justify-content-between align-items-center">
                    <span class="kpi-icon-wrapper"><i class="fas fa-check-circle"></i></span>
                </div>
                <div>
                    <div class="kpi-value" id="kpi-active-products">0</div>
                    <div class="kpi-label">@L("ActiveProducts")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search & Filter Controls -->
    <div class="filter-container mb-4">
        <form id="ProductsSearchForm" class="w-100 mb-0">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="custom-search-input-wrapper">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" name="Keyword" class="form-control txt-search" placeholder="@L("SearchProductsPlaceholder")" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select id="CategoryFilter" name="CategoryId" class="form-select custom-select-filter">
                        <option value="">@L("AllCategories")</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select id="StatusFilter" name="IsActive" class="form-select custom-select-filter">
                        <option value="">@L("AllStatuses")</option>
                        <option value="true">@L("ActiveProducts")</option>
                        <option value="false">@L("InactiveProducts")</option>
                    </select>
                </div>
            </div>
        </form>
    </div>

    <!-- Table Card -->
    <div class="card table-card border-0 rounded-4 mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="ProductsTable" class="table custom-products-table mb-0 w-100">
                    <thead>
                        <tr>
                            <th>@L("Sku")</th>
                            <th>@L("Name")</th>
                            <th>@L("Category")</th>
                            <th class="text-end">@L("CostPrice")</th>
                            <th class="text-end">@L("SalePrice")</th>
                            <th class="text-end">@L("StockQuantity")</th>
                            <th>@L("Unit")</th>
                            <th>@L("Status")</th>
                            <th>@L("Actions")</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Views/Products/_CreateModal.cshtml", Model)

<div class="modal fade" id="ProductEditModal" tabindex="-1" role="dialog" aria-labelledby="ProductEditModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
        </div>
    </div>
</div>
