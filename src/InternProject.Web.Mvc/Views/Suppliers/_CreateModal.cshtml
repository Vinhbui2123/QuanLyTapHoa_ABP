@using InternProject.Web.Models.Common.Modals
@model InternProject.Web.Models.Suppliers.SupplierListViewModel
@{
    Layout = null;
}
<div class="modal fade" id="SupplierCreateModal" tabindex="-1" role="dialog" aria-labelledby="SupplierCreateModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            @await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(L("CreateSupplier")))
            <form name="supplierCreateForm" role="form" class="form-horizontal">
                <div class="modal-body">
                    <div class="form-group row required">
                        <label class="col-md-3 col-form-label" for="supplier-code">@L("Code")</label>
                        <div class="col-md-9">
                            <input id="supplier-code" type="text" name="Code" class="form-control" required maxlength="50">
                        </div>
                    </div>
                    <div class="form-group row required">
                        <label class="col-md-3 col-form-label" for="supplier-name">@L("Name")</label>
                        <div class="col-md-9">
                            <input id="supplier-name" type="text" name="Name" class="form-control" required maxlength="100">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-md-3 col-form-label" for="supplier-phone">@L("Phone")</label>
                        <div class="col-md-9">
                            <input id="supplier-phone" type="text" name="Phone" class="form-control" maxlength="32">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-md-3 col-form-label" for="supplier-contact-person">@L("ContactPerson")</label>
                        <div class="col-md-9">
                            <input id="supplier-contact-person" type="text" name="ContactPerson" class="form-control" maxlength="100">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-md-3 col-form-label" for="supplier-email">@L("Email")</label>
                        <div class="col-md-9">
                            <input id="supplier-email" type="email" name="Email" class="form-control" maxlength="100">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-md-3 col-form-label" for="supplier-address">@L("Address")</label>
                        <div class="col-md-9">
                            <textarea id="supplier-address" name="Address" class="form-control" maxlength="256"></textarea>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-md-3 col-form-label">@L("IsActive")</label>
                        <div class="col-md-9">
                            <div class="form-check mt-2">
                                <input id="supplier-is-active" type="checkbox" name="IsActive" class="form-check-input" value="true" checked>
                                <label class="form-check-label" for="supplier-is-active">@L("Active")</label>
                            </div>
                        </div>
                    </div>
                </div>
                @await Html.PartialAsync("~/Views/Shared/Modals/_ModalFooterWithSaveAndCancel.cshtml")
            </form>
        </div>
    </div>
</div>
