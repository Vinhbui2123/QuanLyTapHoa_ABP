@using InternProject.Web.Models.Common.Modals
@using InternProject.Web.Models.Customers
@model EditCustomerModalViewModel
@{
    Layout = null;
}
@await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(L("EditCustomer")))
<form name="CustomerEditForm" role="form" class="form-horizontal">
    <input type="hidden" name="Id" value="@Model.Customer.Id" />
    <div class="modal-body">
        <div class="form-group row">
            <label class="col-md-3 col-form-label" for="CustomerEditCode">@L("Code")</label>
            <div class="col-md-9">
                <input id="CustomerEditCode" type="text" class="form-control" name="Code" value="@Model.Customer.Code" maxlength="50">
            </div>
        </div>
        <div class="form-group row required">
            <label class="col-md-3 col-form-label" for="CustomerEditName">@L("Name")</label>
            <div class="col-md-9">
                <input id="CustomerEditName" type="text" class="form-control" name="Name" value="@Model.Customer.Name" required maxlength="128">
            </div>
        </div>
        <div class="form-group row">
            <label class="col-md-3 col-form-label" for="CustomerEditPhone">@L("Phone")</label>
            <div class="col-md-9">
                <input id="CustomerEditPhone" type="text" class="form-control" name="Phone" value="@Model.Customer.Phone" maxlength="32">
            </div>
        </div>
        <div class="form-group row">
            <label class="col-md-3 col-form-label" for="CustomerEditAddress">@L("Address")</label>
            <div class="col-md-9">
                <input id="CustomerEditAddress" type="text" class="form-control" name="Address" value="@Model.Customer.Address" maxlength="512">
            </div>
        </div>
        <div class="form-group row">
            <label class="col-md-3 col-form-label" for="CustomerEditIsActive">@L("IsActive")</label>
            <div class="col-md-9">
                <input id="CustomerEditIsActive" type="checkbox" name="IsActive" value="true" @(Model.Customer.IsActive ? "checked" : "") />
            </div>
        </div>
    </div>
    @await Html.PartialAsync("~/Views/Shared/Modals/_ModalFooterWithSaveAndCancel.cshtml")
</form>

<script src="~/view-resources/Views/Customers/_EditModal.js" asp-append-version="true"></script>
