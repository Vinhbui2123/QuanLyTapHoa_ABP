@using InternProject.Web.Startup
@{
    ViewBag.Title = L("StockBatches");
    ViewBag.CurrentPageName = PageNames.StockBatches;
}
@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/StockBatches/Index.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/StockBatches/Index.min.js" asp-append-version="true"></script>
    </environment>
}
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

    .content-wrapper {
        background-color: #f8fafc !important;
        font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    .content-header {
        padding: 0 !important;
    }

    .batches-main-title {
        font-size: 28px;
        font-weight: 700;
        color: #0f172a;
        letter-spacing: -0.02em;
    }

    .batches-subtitle {
        font-size: 14px;
        color: #64748b;
        margin-top: 4px;
    }

    .filter-container {
        background-color: #ffffff;
        border-radius: 12px;
        padding: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.02);
    }

    .custom-search-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .custom-search-input-wrapper .search-icon {
        position: absolute;
        left: 16px;
        color: #94a3b8;
        font-size: 16px;
    }

    .custom-search-input-wrapper input {
        padding-left: 48px;
        height: 48px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        background-color: #ffffff;
        font-size: 14px;
        color: #0f172a;
        transition: all 0.15s ease-in-out;
        width: 100%;
    }

    .custom-search-input-wrapper input:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        outline: none;
    }

    .custom-select-filter {
        height: 48px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        font-size: 14px;
        font-weight: 500;
        color: #334155;
        padding: 0 16px;
        transition: all 0.15s ease-in-out;
        width: 100%;
        background-color: #ffffff;
    }

    .custom-select-filter:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        outline: none;
    }

    .table-card {
        border: 1px solid #e2e8f0 !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02) !important;
    }

    .custom-batches-table {
        border-collapse: separate !important;
        border-spacing: 0 !important;
    }

    .custom-batches-table thead th {
        background-color: #f8fafc !important;
        color: #64748b !important;
        font-size: 12px !important;
        font-weight: 600 !important;
        text-transform: uppercase !important;
        letter-spacing: 0.05em !important;
        padding: 16px 20px !important;
        border-bottom: 1px solid #e2e8f0 !important;
        border-top: none !important;
    }

    .custom-batches-table tbody td {
        padding: 16px 20px !important;
        vertical-align: middle !important;
        font-size: 14px !important;
        color: #334155 !important;
        border-bottom: 1px solid #f1f5f9 !important;
        background-color: #ffffff !important;
    }

    .custom-batches-table tbody tr:hover td {
        background-color: #f8fafc !important;
    }

    .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        border-radius: 9999px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-status-active {
        background-color: #d1fae5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

    .badge-status-expired {
        background-color: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .badge-status-warning {
        background-color: #fef3c7;
        color: #92400e;
        border: 1px solid #fde68a;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="batches-main-title m-0">@L("StockBatches")</h1>
            <p class="batches-subtitle m-0">@L("StockBatchesSubtitle")</p>
        </div>
    </div>

    <!-- Search & Filters -->
    <div class="filter-container mb-4">
        <form id="BatchesSearchForm" class="w-100 mb-0">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="custom-search-input-wrapper">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" name="Keyword" class="form-control txt-search" placeholder="@L("SearchStockBatchesPlaceholder")" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select id="ProductFilter" name="ProductId" class="form-select custom-select-filter">
                        <option value="">@L("AllProductsSelect")</option>
                        @foreach (var p in ViewBag.Products)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select id="SupplierFilter" name="SupplierId" class="form-select custom-select-filter">
                        <option value="">@L("AllSuppliersSelect")</option>
                        @foreach (var s in ViewBag.Suppliers)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select id="ExpiredFilter" name="IsExpiredOnly" class="form-select custom-select-filter">
                        <option value="">@L("AllBatchesSelect")</option>
                        <option value="true">@L("ExpiredBatchesOnly")</option>
                        <option value="false">@L("NonExpiredBatchesOnly")</option>
                    </select>
                </div>
            </div>
        </form>
    </div>

    <!-- Table -->
    <div class="card table-card border-0 rounded-4 mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="BatchesTable" class="table custom-batches-table mb-0 w-100">
                    <thead>
                        <tr>
                            <th>@L("BatchCode")</th>
                            <th>@L("Product")</th>
                            <th>@L("Supplier")</th>
                            <th>@L("ImportPrice")</th>
                            <th>@L("InitialQuantity")</th>
                            <th>@L("RemainingQuantity")</th>
                            <th>@L("ExpiryDate")</th>
                            <th>@L("Status")</th>
                            <th>@L("Actions")</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Dispose Modal -->
<div class="modal fade" id="DisposeBatchModal" tabindex="-1" role="dialog" aria-labelledby="DisposeBatchModalLabel" data-backdrop="static">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="DisposeBatchModalLabel">@L("DisposeStockBatch")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="DisposeBatchForm">
                <div class="modal-body">
                    <input type="hidden" name="StockBatchId" id="dispose-batch-id" />
                    
                    <div class="mb-3">
                        <label class="form-label">@L("BatchCodeLabel")</label>
                        <input type="text" class="form-control" id="dispose-batch-code" readonly />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">@L("CurrentBatchStockLabel")</label>
                        <input type="text" class="form-control" id="dispose-batch-current-qty" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="dispose-qty">@L("DisposeQuantity") <span class="text-danger">*</span></label>
                        <input type="number" name="Quantity" id="dispose-qty" class="form-control" min="1" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="dispose-reason">@L("Reason") <span class="text-danger">*</span></label>
                        <textarea name="Reason" id="dispose-reason" class="form-control" rows="3" placeholder="@L("DisposeReasonPlaceholder")" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@L("Cancel")</button>
                    <button type="submit" class="btn btn-danger save-button">@L("Dispose")</button>
                </div>
            </form>
        </div>
    </div>
</div>
