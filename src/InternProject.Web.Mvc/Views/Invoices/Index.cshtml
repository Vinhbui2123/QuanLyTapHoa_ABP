@using InternProject.Web.Startup
@using InternProject.Authorization
@{
    ViewBag.Title = L("Invoices");
    ViewBag.CurrentPageName = PageNames.Invoices;
}
@section scripts
{
    <environment names="Development">
        <script src="~/view-resources/Views/Invoices/Index.js" asp-append-version="true"></script>
    </environment>

    <environment names="Staging,Production">
        <script src="~/view-resources/Views/Invoices/Index.min.js" asp-append-version="true"></script>
    </environment>
}
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap');

    .content-wrapper {
        background-color: #f8fafc !important;
        font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    .content-header {
        padding: 0 !important;
    }

    .invoices-main-title {
        font-size: 28px;
        font-weight: 700;
        color: #0f172a;
        letter-spacing: -0.02em;
    }

    .invoices-subtitle {
        font-size: 14px;
        color: #64748b;
        margin-top: 4px;
    }

    .btn-create-invoice {
        background-color: #10b981 !important;
        color: #ffffff !important;
        border-radius: 8px;
        padding: 10px 20px;
        font-weight: 600;
        font-size: 14px;
        box-shadow: 0 4px 6px -1px rgba(16, 185, 129, 0.2);
        transition: all 0.2s ease-in-out;
        border: none;
        display: inline-flex;
        align-items: center;
        text-decoration: none;
    }

    .btn-create-invoice:hover {
        background-color: #059669 !important;
        transform: translateY(-1px);
        box-shadow: 0 6px 12px -1px rgba(16, 185, 129, 0.3);
        color: #ffffff !important;
    }

    /* KPI Cards */
    .kpi-card {
        border-radius: 16px;
        padding: 24px;
        color: #ffffff;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.05);
        transition: all 0.2s ease-in-out;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .kpi-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px -5px rgba(0, 0, 0, 0.1);
    }

    .kpi-card-blue {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    }
    
    .kpi-card-green {
        background: linear-gradient(135deg, #10b981, #059669);
    }
    
    .kpi-card-red {
        background: linear-gradient(135deg, #ef4444, #b91c1c);
    }

    .kpi-icon-wrapper {
        width: 44px;
        height: 44px;
        background-color: rgba(255, 255, 255, 0.18);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .kpi-value {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: -0.03em;
        margin-top: 15px;
    }

    .kpi-label {
        font-size: 14px;
        opacity: 0.9;
        margin-top: 4px;
        font-weight: 500;
    }

    /* Search & Filter Containers */
    .filter-container {
        background-color: #ffffff;
        border-radius: 12px;
        padding: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.02);
    }

    .custom-search-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .custom-search-input-wrapper .search-icon {
        position: absolute;
        left: 16px;
        color: #94a3b8;
        font-size: 16px;
    }

    .custom-search-input-wrapper input {
        padding-left: 48px;
        height: 48px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        background-color: #ffffff;
        font-size: 14px;
        color: #0f172a;
        transition: all 0.15s ease-in-out;
        width: 100%;
    }

    .custom-search-input-wrapper input:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        outline: none;
    }

    .custom-select-filter {
        height: 48px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        font-size: 14px;
        font-weight: 500;
        color: #334155;
        padding: 0 16px;
        transition: all 0.15s ease-in-out;
        width: 100%;
        background-color: #ffffff;
    }

    .custom-select-filter:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        outline: none;
    }

    /* DataTable Styles */
    .table-card {
        border: 1px solid #e2e8f0 !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02) !important;
    }

    .custom-invoices-table {
        border-collapse: separate !important;
        border-spacing: 0 !important;
    }

    .custom-invoices-table thead th {
        background-color: #f8fafc !important;
        color: #64748b !important;
        font-size: 12px !important;
        font-weight: 600 !important;
        text-transform: uppercase !important;
        letter-spacing: 0.05em !important;
        padding: 16px 20px !important;
        border-bottom: 1px solid #e2e8f0 !important;
        border-top: none !important;
    }

    .custom-invoices-table tbody td {
        padding: 16px 20px !important;
        vertical-align: middle !important;
        font-size: 14px !important;
        color: #334155 !important;
        border-bottom: 1px solid #f1f5f9 !important;
        background-color: #ffffff !important;
    }

    .custom-invoices-table tbody tr:hover td {
        background-color: #f8fafc !important;
    }

    .invoice-code-link {
        color: #2563eb !important;
        font-weight: 700;
        text-decoration: none;
        transition: color 0.15s ease-in-out;
    }

    .invoice-code-link:hover {
        color: #1d4ed8 !important;
        text-decoration: underline;
    }

    /* Status Badges */
    .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        border-radius: 9999px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-status-completed {
        background-color: #d1fae5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

    .badge-status-cancelled {
        background-color: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .invoice-action-detail {
        color: #2563eb !important;
        font-weight: 500;
        text-decoration: none;
        transition: color 0.15s ease-in-out;
    }

    .invoice-action-detail:hover {
        color: #1d4ed8 !important;
        text-decoration: underline;
    }

    /* Pagination Styling overrides */
    .dataTables_wrapper .dataTables_paginate {
        margin: 20px 0 !important;
        padding-top: 10px !important;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 6px;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button {
        border-radius: 8px !important;
        border: 1px solid #cbd5e1 !important;
        background: #ffffff !important;
        color: #475569 !important;
        padding: 6px 14px !important;
        font-size: 13px !important;
        font-weight: 500 !important;
        cursor: pointer !important;
        transition: all 0.15s ease-in-out !important;
        margin: 0 2px !important;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
        background: #f1f5f9 !important;
        color: #0f172a !important;
        border-color: #94a3b8 !important;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button.current,
    .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
        background: #2563eb !important;
        color: #ffffff !important;
        border-color: #2563eb !important;
        font-weight: 600 !important;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button.disabled,
    .dataTables_wrapper .dataTables_paginate .paginate_button.disabled:hover {
        background: #f8fafc !important;
        color: #94a3b8 !important;
        border-color: #e2e8f0 !important;
        cursor: not-allowed !important;
    }

    .dataTables_wrapper .dataTables_info {
        font-size: 13px !important;
        color: #64748b !important;
        margin-top: 24px !important;
    }
</style>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="invoices-main-title m-0">@L("Invoices")</h1>
            <p class="invoices-subtitle m-0">@L("ManageInvoicesSubtitle")</p>
        </div>
        <div>
            @if (IsGranted(PermissionNames.Pages_Invoices_Create))
            {
                <a asp-action="Create" class="btn btn-create-invoice">
                    <i class="fas fa-shopping-cart mr-2"></i>
                    @L("CreateInvoice")
                </a>
            }
        </div>
    </div>

    <!-- KPIs -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="kpi-card kpi-card-green">
                <div class="kpi-card-header d-flex justify-content-between">
                    <span class="kpi-icon-wrapper"><i class="fas fa-donate"></i></span>
                </div>
                <div>
                    <div class="kpi-value" id="kpi-total-revenue">0 đ</div>
                    <div class="kpi-label">@L("TotalRevenue")</div>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="kpi-card kpi-card-blue">
                <div class="kpi-card-header d-flex justify-content-between">
                    <span class="kpi-icon-wrapper"><i class="fas fa-file-invoice-dollar"></i></span>
                </div>
                <div>
                    <div class="kpi-value" id="kpi-completed-invoices">0</div>
                    <div class="kpi-label">@L("CompletedInvoices")</div>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="kpi-card kpi-card-red">
                <div class="kpi-card-header d-flex justify-content-between">
                    <span class="kpi-icon-wrapper"><i class="fas fa-file-excel"></i></span>
                </div>
                <div>
                    <div class="kpi-value" id="kpi-cancelled-invoices">0</div>
                    <div class="kpi-label">@L("CancelledInvoices")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="filter-container mb-4">
        <form id="InvoicesSearchForm" class="w-100 mb-0">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="custom-search-input-wrapper">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" name="Keyword" class="form-control txt-search" placeholder="@L("SearchInvoicesPlaceholder")" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select id="PaymentMethodFilter" name="PaymentMethod" class="form-select custom-select-filter">
                        <option value="">-- @L("All") @L("PaymentMethod") --</option>
                        <option value="1">@L("CashPayment")</option>
                        <option value="2">@L("BankTransfer")</option>
                        <option value="3">@L("MomoWallet")</option>
                        <option value="4">@L("ZaloPayWallet")</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select id="StatusFilter" name="Status" class="form-select custom-select-filter">
                        <option value="">-- @L("All") @L("Status") --</option>
                        <option value="1">@L("CompletedInvoices")</option>
                        <option value="2">@L("CancelledInvoices")</option>
                    </select>
                </div>
            </div>
        </form>
    </div>

    <!-- Table -->
    <div class="card table-card border-0 rounded-4 mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="InvoicesTable" class="table custom-invoices-table mb-0 w-100">
                    <thead>
                        <tr>
                            <th>@L("InvoiceNumber")</th>
                            <th>@L("CustomerName")</th>
                            <th>@L("Cashier")</th>
                            <th class="text-end">@L("TotalAmount")</th>
                            <th>@L("PaymentMethod")</th>
                            <th>@L("Status")</th>
                            <th>@L("InvoiceDate")</th>
                            <th>@L("Actions")</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Details Modal -->
<div class="modal fade" id="InvoiceDetailModal" tabindex="-1" role="dialog" aria-labelledby="InvoiceDetailModalLabel" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <!-- Loaded via AJAX -->
        </div>
    </div>
</div>
