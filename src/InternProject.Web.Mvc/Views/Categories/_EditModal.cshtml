@using InternProject.Web.Models.Common.Modals
@using InternProject.Web.Models.Categories
@model EditCategoryModalViewModel
@{
    Layout = null;
}
@await Html.PartialAsync("~/Views/Shared/Modals/_ModalHeader.cshtml", new ModalHeaderViewModel(L("EditCategory")))
<form name="CategoryEditForm" role="form" class="form-horizontal">
    <input type="hidden" name="Id" value="@Model.Category.Id" />
    <div class="modal-body">
        <div class="form-group row required">
            <label class="col-md-3 col-form-label" for="CategoryEditName">@L("Name")</label>
            <div class="col-md-9">
                <input id="CategoryEditName" type="text" class="form-control" name="Name" value="@Model.Category.Name" required maxlength="100">
            </div>
        </div>
        <div class="form-group row">
            <label class="col-md-3 col-form-label" for="CategoryEditDescription">@L("Description")</label>
            <div class="col-md-9">
                <input id="CategoryEditDescription" type="text" class="form-control" name="Description" value="@Model.Category.Description" maxlength="500">
            </div>
        </div>
        <div class="form-group row">
            <label class="col-md-3 col-form-label" for="CategoryEditIsActive">@L("IsActive")</label>
            <div class="col-md-9">
                <input id="CategoryEditIsActive" type="checkbox" name="IsActive" value="true" @(Model.Category.IsActive ? "checked" : "") />
            </div>
        </div>
    </div>
    @await Html.PartialAsync("~/Views/Shared/Modals/_ModalFooterWithSaveAndCancel.cshtml")
</form>

<script src="~/view-resources/Views/Categories/_EditModal.js" asp-append-version="true"></script>
